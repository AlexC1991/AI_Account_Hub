__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local env files.
.venv/
venv/
env/
.env
.env.*

# OS/editor noise.
.DS_Store
Thumbs.db
.vs/
*.swp
*.tmp
*.bak
*.log

# Local provider/account state. These may contain auth/session metadata.
.claude/
.codex-account-launcher/
.codex-accounts/
.ai-account-hub/
provider-discovery.json

# Claude Desktop state must never be committed if a diagnostic or an old build
# accidentally targets the repository root. These names are anchored so normal
# project files in subdirectories are unaffected.
/config.json
/claude_desktop_config.json
/buddy-tokens.json
/ant-did
/Local State
/Preferences
/DIPS
/DIPS-wal
/DIPS-shm
/Network/
/Local Storage/
/IndexedDB/
/Session Storage/
/Partitions/
/WebStorage/
/SharedStorage/
/blob_storage/
/Shared Dictionary/

# (The runtime icon cache lives under ~/.codex-account-launcher, already ignored;
# the bundled provider icons in ai_account_hub/assets/ are tracked on purpose.)

# Local-only, never shipped in the public repo: private notes (local-docs/),
# research/schemas/probes (work/), and the test suite. Folders stay on the
# maintainer's machine.
/local-docs/
/work/
/tests/
/conftest.py
test_*.py
**/test_*.py

# Public docs live at Docs/*.md; the private notes subdir stays local.
/Docs/private/

# Design/prototype launchers and other stray .bat/.cmd — only the top-level
# Start-AI-Account-Hub.bat launcher ships.
outputs/**/*.bat
outputs/**/open-*.bat
outputs/runcodex.bat
