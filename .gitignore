.codex-accounts/
.ai-account-hub/
provider-discovery.json

# Claude Desktop state must never be committed if a diagnostic or an old build
# accidentally targets the repository root. These names are anchored so normal
# project files in subdirectories are unaffected.
/config.json
/claude_desktop_config.json
/buddy-tokens.json
/ant-did
/Local State
/Preferences
/DIPS
/DIPS-wal
/DIPS-shm
/Network/
/Local Storage/
/IndexedDB/
/Session Storage/
/Partitions/
/WebStorage/
/SharedStorage/
/blob_storage/
/Shared Dictionary/


# (The runtime icon cache lives under ~/.codex-account-launcher, already ignored;
# the bundled provider icons in ai_account_hub/assets/ are tracked on purpose.)

# Local-only, never shipped in the public repo: private notes (local-docs/),
# research/schemas/probes (work/), and the test suite. Folders stay on the
# maintainer's machine.
/local-docs/
/work/
/prototypes/
/tests/
/conftest.py
test_*.py
**/test_*.py

# Parked/disabled subsystem: the native "Coding" passthrough (transports,
# history readers, coding view, permission bridge). Kept locally for reference
# but not part of the shipped Command Center/Accounts app. See _disabled/README.md.
/_disabled/

# Public docs live at docs/*.md; the private notes subdir stays local.
/docs/private/

# Local design explorations and implementation working notes. Prototypes may
# contain fake account/model data and are not part of the public application.
/prototypes/
/docs/PERSONAL_MODEL_ANALYTICS_PLAN.md
